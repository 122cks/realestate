# .env.local.sample
# 복사해서 `.env.local`로 이름을 바꾸고 실제 키를 입력하세요.
# 절대 실제 키가 들어있는 `.env.local`을 공개 저장소에 커밋하지 마세요.

# Google (공개 시트 접근용 API Key)
VITE_GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY

# Google OAuth 클라이언트 ID (OAuth로 시트에 접근하려면 설정)
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_OAUTH_CLIENT_ID

# 기본 시트 식별자 (변경하지 않아도 됩니다)
VITE_SPREADSHEET_ID=16urMn_RdMuw99MLpvASHG07h5EuKsCESc25-CcGH9Lo
VITE_SHEET_GID=162008221

# Kakao JavaScript 앱 키
VITE_KAKAO_JS_KEY=YOUR_KAKAO_JAVASCRIPT_KEY

# 사용법:
# 1) 이 파일을 복사하여 `.env.local`로 저장하세요.
# 2) 각 항목에 실제 값을 넣으세요.
# 3) 개발 서버 실행: npm run dev
